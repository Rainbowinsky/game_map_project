{
  "name": "@fantasy-map/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint src --max-warnings=0",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "prisma:validate": "prisma validate",
    "start": "node dist/main.js",
    "test": "prisma generate && vitest run",
    "test:integration": "prisma generate && vitest run --config vitest.integration.config.ts",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fantasy-map/map-model": "workspace:*",
    "@fantasy-map/shared": "workspace:*",
    "@fantasy-map/validation": "workspace:*",
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/throttler": "^6.5.0",
    "@node-rs/argon2": "2.0.2",
    "@prisma/adapter-mariadb": "7.8.0",
    "@prisma/client": "7.8.0",
    "dotenv": "^17.2.0",
    "helmet": "^8.1.0",
    "jose": "6.2.3",
    "mariadb": "^3.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sanitize-html": "^2.17.6",
    "sharp": "^0.35.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.0",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.2.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^6.0.3",
    "prisma": "7.8.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.4",
    "vitest": "^3.2.0"
  }
}
