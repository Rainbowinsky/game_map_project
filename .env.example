# API runtime (server-only values must never use the VITE_ prefix)
NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=3000
DATABASE_URL=mysql://fantasy_map:change-me@127.0.0.1:3306/fantasy_map
CORS_ORIGINS=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-development-secret
JWT_ISSUER=fantasy-map-api
JWT_AUDIENCE=fantasy-map-web
JWT_ACCESS_TTL_SECONDS=900
STORAGE_ROOT=./apps/api/storage
LOG_LEVEL=info
REQUEST_BODY_LIMIT=1mb
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=120

# Web runtime (Vite exposes only VITE_-prefixed values to browser code)
VITE_API_BASE_URL=http://localhost:3000/api/v1
